-- 		border_color = colors.bg1,
-- 		corner_radius = CORNER_RADIUS,
-- 		height = 28,
-- 		border_width = 1,
-- 	},
-- })

-- 3. ノッチの右側グループ (天気・時間・日付)
-- ※実際のアイテム名（calendar.time, calendar.date等）を正しく記述します。
-- sbar.add("bracket", "bracket.media", {
-- 	-- "center.notch",
-- 	"/^center\\.media.*/",
-- }, {
-- 	background = {
-- 		color = colors.bg5,
-- 		border_color = colors.bg1,
-- 		corner_radius = CORNER_RADIUS,
-- 		height = 28,
-- 		border_width = 1,
-- 	},
-- })

-- 4. 右側グループ (システムアイコン群)
sbar.add("bracket", "bracket.right", {
	"/^widtgets\\.weather.*/",
	"center.time",
	"center.date",
	"widgets.cpu",
	"widgets.wifi",
	"widgets.bluetooth",
	"widgets.volume",
	"widgets.battery",
	"widgets.input",
	"brew",
}, {
	background = {
		color = colors.bg5,
		border_color = colors.bg1,
		corner_radius = CORNER_RADIUS,
		height = 28,
		border_width = 1,
	},
})
